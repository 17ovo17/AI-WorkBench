{
  "version": 1,
  "purpose": "Dangerous endpoint guard cases. These cases must not perform real destructive actions.",
  "default_headers": {
    "X-Test-Dry-Run": "true"
  },
  "cases": [
    {
      "id": "remote-exec-l4-root-delete",
      "method": "POST",
      "path": "/api/v1/remote/exec",
      "risk": "L4",
      "expected": "reject",
      "body": { "ip": "192.168.1.7", "protocol": "winrm", "username": "test", "command": "rm -rf /" }
    },
    {
      "id": "remote-exec-non-whitelist-host",
      "method": "POST",
      "path": "/api/v1/remote/exec",
      "risk": "L3",
      "expected": "reject",
      "body": { "ip": "8.8.8.8", "protocol": "ssh", "username": "test", "command": "cat /etc/os-release" }
    },
    {
      "id": "remote-uninstall-missing-batch",
      "method": "POST",
      "path": "/api/v1/remote/uninstall-catpaw",
      "risk": "L3",
      "expected": "reject_or_confirm_required",
      "body": { "ip": "192.168.1.7", "protocol": "winrm", "username": "test" }
    },
    {
      "id": "remote-install-invalid-platform-url",
      "method": "POST",
      "path": "/api/v1/remote/install-catpaw",
      "risk": "L3",
      "expected": "reject",
      "headers": { "X-Platform-URL": "http://169.254.169.254/latest/meta-data" },
      "body": { "ip": "192.168.1.7", "protocol": "winrm", "username": "test", "mode": "run" }
    },
    {
      "id": "credential-inline-secret-leak-check",
      "method": "POST",
      "path": "/api/v1/credentials",
      "risk": "L2",
      "expected": "no_secret_echo",
      "body": { "id": "aiw-test-sensitive", "name": "aiw-test-sensitive", "ip": "192.168.1.7", "protocol": "winrm", "port": 5985, "username": "admin", "password": "SHOULD_NOT_ECHO" }
    },
    {
      "id": "diagnose-remote-credential-non-whitelist",
      "method": "POST",
      "path": "/api/v1/diagnose",
      "risk": "L2",
      "expected": "reject_or_no_remote_exec",
      "body": { "ip": "8.8.8.8", "trigger": "manual", "credential_id": "missing" }
    }
  ]
}
