# ===== AI WorkBench .gitignore =====
# 只上传纯净源码，排除所有运行时产物、调试文件、临时文件

# === 编译产物 ===
api/ai-workbench-api
api/ai-workbench-api.exe
api/aiw-api.exe~
api/api.exe~
api/data/
api/vendor/
*.exe
*.dll
*.so

# === 前端构建 ===
web/node_modules/
web/dist/
web/test-results/
web/tests/

# === 运行时 ===
logs/
*.log
nohup.out
api/config.yaml
prometheus-data/
api/assets/*.db

# === IDE ===
.idea/
.vscode/
*.swp
*.swo

# === OS ===
.DS_Store
Thumbs.db
desktop.ini

# === 密钥 ===
.env
*.pem
*.key

# === AI 工具配置（全局配置，不属于项目） ===
CLAUDE.md
AGENTS.md
.mcp.json
.claude/
.codex/
.playwright-mcp/
output/

# === 根目录临时文件（调试/快照/测试产物） ===
mcp-*.md
mcp-*.txt
readonly-*.md
topology-*.md
test-results.md
tmp_*.txt
start-wsl.sh
stop-wsl.sh
400
/*.png
/*.jpeg
FAKE-APP-METRICS-GUIDE.md
FINAL-TEST-REPORT.md
INSPECTION-OPTIMIZATION-DONE.md
ai-config-after-key-overwrite-check.md

# === 测试文档和脚本（全部排除） ===
scripts/testing/
docs/testing/
.test-evidence/

# === 临时文件 ===
*.tmp
*.bak
tmp/
